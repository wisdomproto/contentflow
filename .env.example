# ===========================================
# ContentFlow AI — Environment Variables
# Copy this file to .env.local and fill in your keys
# ===========================================

# ------ Google Gemini AI ------
GEMINI_API_KEY=your_gemini_api_key_here

# ------ Naver API (키워드 인텔리전스) ------
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ------ Naver 검색광고 API (키워드 도구) ------
NAVER_AD_API_KEY=your_naver_ad_api_key
NAVER_AD_SECRET_KEY=your_naver_ad_secret_key
NAVER_AD_CUSTOMER_ID=your_naver_ad_customer_id
